<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="${LOGBACK_CONFIGURATION_DEBUG:-false}">
    <conversionRule conversionWord="pii"
                    converterClass="uk.gov.hmcts.reform.civil.logging.PiiRedactingConverter"/>
    <property name="CONSOLE_LOG_PATTERN"
              value="%d{${LOGBACK_DATE_FORMAT:-yyyy-MM-dd'T'HH:mm:ss.SSS}} %-5level [%thread] %logger{${LOGGER_LENGTH:-50}} %pii(%msg%n%ex{${EXCEPTION_LENGTH:-50}})"/>
    <include resource="reform-base.xml"/>

    <root level="${ROOT_LOGGING_LEVEL:-INFO}">
        <appender-ref ref="${ROOT_APPENDER:-ASYNC_CONSOLE}"/>
    </root>
</configuration>
