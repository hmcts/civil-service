      <bpmn:incoming>Flow_08avc9f</bpmn:incoming>
      <bpmn:outgoing>Flow_1yfyxrt</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1yfyxrt" sourceRef="NotifyDecisionOnReconsiderationRequestNotifier" targetRef="GenerateDashboardNotificationsDecisionReconsideration" />
    <bpmn:sequenceFlow id="Flow_1737ozj" sourceRef="SendToDefendantLIP" targetRef="NotifyDecisionOnReconsiderationRequestNotifier" />
    <bpmn:sequenceFlow id="Flow_08avc9f" sourceRef="Gateway_0zj33b5" targetRef="NotifyDecisionOnReconsiderationRequestNotifier">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${(empty flowFlags.UNREPRESENTED_DEFENDANT_ONE  || (!empty flowFlags.UNREPRESENTED_DEFENDANT_ONE &amp;&amp; !flowFlags.UNREPRESENTED_DEFENDANT_ONE)) || (empty flowFlags.WELSH_ENABLED || (!empty flowFlags.WELSH_ENABLED &amp;&amp; !flowFlags.WELSH_ENABLED)) }</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:textAnnotation id="TextAnnotation_1kl1nm4">
      <bpmn:text>LR or LiPclaimant ?</bpmn:text>
    </bpmn:textAnnotation>
