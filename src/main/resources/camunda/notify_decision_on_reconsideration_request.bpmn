    <bpmn:serviceTask id="GenerateDashboardNotificationsDecisionReconsideration" name="Generate Dashboard Notifications" camunda:type="external" camunda:topic="processCaseEvent">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="caseEvent">DASHBOARD_NOTIFICATION_EVENT</camunda:inputParameter>
