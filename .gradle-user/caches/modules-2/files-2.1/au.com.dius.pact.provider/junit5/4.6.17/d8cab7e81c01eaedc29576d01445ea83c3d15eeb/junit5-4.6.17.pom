      <artifactId>support</artifactId>
      <version>4.6.17</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>au.com.dius.pact.core</groupId>
      <artifactId>pactbroker</artifactId>
      <version>4.6.17</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
