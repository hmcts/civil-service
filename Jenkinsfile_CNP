withPipeline(type, product, component) {
  env.PACT_BROKER_FULL_URL = 'https://pact-broker.platform.hmcts.net'
  env.EM_CCD_ORCHESTRATOR_URL = 'http://em-ccd-orchestrator-aat.service.core-compute-aat.internal'
  env.PACT_BROKER_URL = "pact-broker.platform.hmcts.net"
  env.PACT_BROKER_PORT = "443"
  env.PACT_BROKER_SCHEME = "https"
  env.ENABLE_SECURE_URL = true
  env.GRADLE_OPTS = "-Dorg.gradle.workers.max=3"
  env.CHECKSTYLE_SKIP = (env.CHANGE_ID != null) ? "false" : "true"
  env.BEFTA_S2S_CLIENT_ID = "ccd_data"
  env.CAMUNDA_DEFINITION_BRANCH = camundaBranch
  env.DMN_DEFINITION_BRANCH = dmnBranch
  env.WIREMOCK_MAPPINGS_BRANCH = wiremockMappingsBranch
  env.UNASSIGN_CASES = true

  enableHighLevelDataSetup("", true)
  loadVaultSecrets(secrets)

  onPR {
    env.ENVIRONMENT = "preview"
    env.NODE_TLS_REJECT_UNAUTHORIZED = "0"
    env.CCD_DEFINITION_BRANCH = checkForCcdDefinitionBranchLabel()
    env.PR_FT_GROUPS = getFunctionalTestsGroups()

    setPreviewUrls(product, component)

    enablePactAs([AppPipelineDsl.PactRoles.CONSUMER, AppPipelineDsl.PactRoles.PROVIDER])
    before('build') {
      sh """
      ./bin/validate-migration-files.sh ${env.CHANGE_BRANCH} ${env.CHANGE_TARGET} --jenkins
       """
    }
  }

  onMaster {
    env.ENVIRONMENT = "aat"
    env.CCD_DEFINITION_BRANCH = "master"
    env.SKIP_COMMON_AAT_CCD_SETUP = "true"

    afterSuccess('akschartsinstall') {
      runStagingHighLevelDataSetup()
    }

    enablePactAs([AppPipelineDsl.PactRoles.CONSUMER, AppPipelineDsl.PactRoles.PROVIDER])
  }

  afterAlways('test') {
    steps.archiveArtifacts allowEmptyArchive: true, artifacts: '**/build/reports/jacoco/**'
  }

  afterAlways('pact-provider-verification') {
    steps.archiveArtifacts allowEmptyArchive: true, artifacts: '**/reports/tests/**/*'
  }

  afterAlways('smoketest:preview') {
    archiveSmokeTestResults()
  }

  afterAlways('functionalTest:preview') {
    publishFunctionalTestResults()
  }

  before('smoketest:aat') {
    setStagingUrls()
  }

  afterAlways('smoketest:aat') {
    archiveSmokeTestResults()
  }

  afterAlways('functionalTest:aat') {
    publishFunctionalTestResults()
  }

  before('functionalTest:preview') {
    prepareFunctionalTests(checkForRunAllFunctionalTests(env.BRANCH_NAME))
  }

  before('functionalTest:aat') {
    prepareFunctionalTests(false)
    setStagingUrls()
  }
}

def checkForRunAllFunctionalTests(branch_name) {
  return new GithubAPI(this).getLabelsbyPattern(branch_name, "runAllFunctionalTests").contains("runAllFunctionalTests")
}

def checkForDisableWiremockLabel(branch_name) {
  return new GithubAPI(this).getLabelsbyPattern(branch_name, "disableWiremock").contains("disableWiremock")
}

def checkForCcdDefinitionBranchLabel() {
  def githubApi = new GithubAPI(this)
  for (label in githubApi.getLabelsbyPattern(env.BRANCH_NAME, "civilDefinitionBranch:")) {
    return label.minus("civilDefinitionBranch:").trim()
  }
  return "master"
}

def getFunctionalTestsGroups() {
  def githubApi = new GithubAPI(this)
  def functionalTestGroups = []
  for (label in githubApi.getLabelsbyPattern(env.BRANCH_NAME, "pr_ft_")) {
    functionalTestGroups.add(label.substring(6, label.length()))
  }
  return functionalTestGroups.join(",")
}

def archiveSmokeTestResults() {
  archiveArtifacts allowEmptyArchive: true, artifacts: 'test-results/smokeTest/**/*'
}

def publishFunctionalTestResults() {
  sh 'npx allure generate test-results/functional/allure-results --clean -o test-results/functional/allure-report'
  publishHTML([
    allowMissing: false,
    alwaysLinkToLastBuild: true,
    keepAll: true,
    reportDir: 'test-results/functional/allure-report',
    reportFiles: 'index.html',
    reportName: 'Non-Prod E2E Allure Report'
  ])
  archiveArtifacts allowEmptyArchive: true, artifacts: 'test-results/functional/**/*'
}

def prepareFunctionalTests(boolean runAllFunctionalTests) {
  if (runAllFunctionalTests) {
    env.RUN_ALL_FUNCTIONAL_TESTS = true
  } else {
    copyPrevFailedAndNotExecutedTestFilesJson()
  }
  copyPreviousAllureHistory()
}

def copyPrevFailedAndNotExecutedTestFilesJson() {
  def buildFound = false
  def buildNumber = currentBuild.previousBuild ? currentBuild.previousBuild.number : 0
  def minBuildNumber = ((buildNumber - 8) > 0) ? buildNumber - 8 : 0
  while (!buildFound && buildNumber > minBuildNumber) {
    try {
      copyArtifacts projectName: env.JOB_NAME, selector: specific("${buildNumber}"), filter: "test-results/functional/testFilesReport.json"
      buildFound = true
    } catch (Exception error) {
      echo "artifact not found: " + error.toString()
      buildNumber--
    }
  }
}

def copyPreviousAllureHistory() {
  def buildFound = false
  def buildNumber = currentBuild.previousBuild ? currentBuild.previousBuild.number : 0
  def minBuildNumber = ((buildNumber - 8) > 0) ? buildNumber - 8 : 0
  def targetDir = "test-results/functional/allure-results/history"

  while (!buildFound && buildNumber > minBuildNumber) {
    try {
      copyArtifacts(
        projectName: env.JOB_NAME,
        selector: specific("${buildNumber}"),
        filter: "test-results/functional/allure-report/history/*",
        target: targetDir,
        flatten: true
      )

      buildFound = true
      echo "Successfully imported Allure history from build ${buildNumber}"
    } catch (Exception error) {
      echo "Allure history artifact not found in build ${buildNumber}. Trying previous..."
      buildNumber--
    }
  }
}

