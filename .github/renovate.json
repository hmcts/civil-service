{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>hmcts/.github:renovate-config",
    "local>hmcts/.github//renovate/automerge-all"
  ],
  "labels": [
    "dependencies"
  ],
  "automergeSchedule": ["after 8am and before 11am every weekday"],
  "schedule": ["after 8am and before 11am every weekday"],
  "rebaseWhen": "conflicted",
  "automergeStrategy": "squash",
  "prConcurrentLimit": 5,
  "helmv3": {
    "bumpVersion": "patch"
  },
  "regexManagers": [
    {
      "fileMatch": [
        "^Dockerfile$"
      ],
      "matchStrings": [
        "datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\sARG .*?_VERSION=(?<currentValue>.*)\\s"
      ]
    }
  ],
  "packageRules": [
    {
      "matchPackagePatterns": ["pact"],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "com.github.hmcts:auth-checker-lib",
        "com.github.hmcts:payments-java-client",
        "com.github.hmcts:ccd-case-document-am-client",
        "com.github.hmcts:core-case-data-store-client"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "description": "Restrict HMCTS library upgrades to minor/patch versions. Major versions may introduce incompatibilities with Spring Boot or other core dependencies (e.g., ccd-case-document-am-client v1.60.0 requires Spring Boot 4.0.6, incompatible with project's Spring Boot 3.3.7)"
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "All non-major updates",
      "groupSlug": "all-non-major",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 4pm every weekday"]
    },
    {
      "matchPackagePatterns": ["^org\\.camunda\\.bpm"],
      "groupName": "Camunda updates",
      "groupSlug": "camunda",
      "automerge": false,
      "description": "Camunda upgrades are isolated in their own group and require manual review to prevent build failures"
    },
    {
      "matchManagers": ["helmv3"],
      "groupName": "Helm chart updates",
      "groupSlug": "helm-charts",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 4pm every weekday"]
    },
    {
      "matchPackagePatterns": [
        "org.springframework",
        "org.springdoc",
        "spring-boot",
        "spring-cloud",
        "jakarta.persistence",
        "org.hibernate"
      ],
      "groupName": "Spring Boot and related updates",
      "groupSlug": "spring-boot-related",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 4pm every weekday"]
    },
    {
      "matchManagers": ["terraform"],
      "groupName": "Terraform updates",
      "groupSlug": "terraform",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 4pm every weekday"]
    },
    {
      "matchPackagePatterns": [
        "org.projectlombok",
        "io.freefair.lombok"
      ],
      "groupName": "Lombok updates",
      "groupSlug": "lombok",
      "automerge": true,
      "automergeType": "pr",
      "automergeSchedule": ["before 4pm every weekday"]
    }
  ]
}
